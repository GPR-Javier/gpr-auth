<component name="ProjectRunConfigurationManager">
  <!--
    Runs gpr-auth as a plain IDE Application that IntelliJ owns, so "Stop" kills the JVM and frees
    port 8081 cleanly. Use THIS instead of any Maven exec:exec config (which forks a child JVM that
    survives Stop and keeps holding the port).
  -->
  <configuration default="false" name="GprAuthApplication" type="Application" factoryName="Application">
    <option name="MAIN_CLASS_NAME" value="com.gpr.auth.GprAuthApplication" />
    <module name="gpr-auth" />
    <option name="VM_PARAMETERS" value="" />
    <option name="PROGRAM_PARAMETERS" value="" />
    <method v="2">
      <option name="Make" enabled="true" />
    </method>
  </configuration>
</component>